# Flash Sale System - Environment Variables

# Server
HOST=0.0.0.0
PORT=3000

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379

# PostgreSQL
DB_HOST=localhost
DB_PORT=5432
DB_NAME=flashsale
DB_USER=flashsale
DB_PASSWORD=flashsale

# Sale Configuration
# SALE_START_TIME=  # Unix timestamp (ms). Default: now + 1 min
# SALE_END_TIME=    # Unix timestamp (ms). Default: now + 61 min
SALE_TOTAL_STOCK=100
